---
interface Props {
  steps: Array<{ title: string; description: string }>;
}

const { steps } = Astro.props;
---

<div class="relative">
  <!-- Connecting line (desktop only) -->
  <div
    class="hidden md:block absolute top-8 left-0 right-0 h-0.5 bg-gradient-to-r from-text-primary/10 via-text-primary/30 to-text-primary/10"
    aria-hidden="true"
  ></div>

  <!-- Steps grid -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-6">
    {steps.map((step, index) => (
      <div
        class="scroll-reveal relative flex flex-col items-center text-center"
        style={`transition-delay: ${index * 150}ms`}
      >
        <!-- Step number circle -->
        <div class="relative z-10 w-16 h-16 rounded-full border-2 border-text-primary bg-bg-primary flex items-center justify-center mb-4">
          <span class="text-xl font-bold text-text-primary">{index + 1}</span>
        </div>

        <!-- Step content -->
        <h3 class="text-lg font-semibold text-text-primary mb-2">{step.title}</h3>
        <p class="text-sm text-text-secondary leading-relaxed">{step.description}</p>
      </div>
    ))}
  </div>
</div>
