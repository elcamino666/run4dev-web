---
interface Props {
  alt: string;
  aspectRatio?: string;
  class?: string;
}

const { alt, aspectRatio = '16/9', class: className } = Astro.props;
---

<div
  class:list={[
    'rounded-2xl bg-bg-surface/50 border border-border flex flex-col items-center justify-center gap-3 p-6',
    className,
  ]}
  style={`aspect-ratio: ${aspectRatio}`}
  role="img"
  aria-label={alt}
>
  <!-- Image icon SVG -->
  <svg
    class="w-12 h-12 text-text-muted/40"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
    <circle cx="8.5" cy="8.5" r="1.5" />
    <polyline points="21 15 16 10 5 21" />
  </svg>

  <!-- Alt text as caption -->
  <span class="text-xs text-text-muted/50 text-center">{alt}</span>
</div>
