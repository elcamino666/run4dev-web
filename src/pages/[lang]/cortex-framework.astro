---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ParticleHero from '../../components/ParticleHero.astro';
import GlowCard from '../../components/GlowCard.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import CTASection from '../../components/CTASection.astro';
import { useTranslations, getLocalizedPath, type Lang } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'it' } },
  ];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Cortex",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Node.js",
  programmingLanguage: "TypeScript",
  author: { "@type": "Organization", name: "Run4Dev" },
};
---

<BaseLayout
  title={t.seo.cortex.title}
  description={t.seo.cortex.description}
  jsonLd={jsonLd}
  page="cortex-framework"
>
  <!-- Hero Section -->
  <ParticleHero>
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold max-w-4xl mx-auto text-text-primary">
      {t.cortex.hero.h1}
    </h1>
    <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mt-6">
      {t.cortex.hero.subtitle}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center mt-8 gap-4">
      <a
        href={getLocalizedPath(lang, '/contact')}
        class="bg-bg-dark text-bg-primary px-8 py-4 rounded-full font-semibold text-lg transition-all duration-300 hover:bg-bg-dark/90 hover:scale-[1.02]"
      >
        {t.cortex.hero.ctaPrimary}
      </a>
      <a
        href="#code-example"
        class="border border-text-primary text-text-primary px-8 py-4 rounded-full font-semibold text-lg transition-all duration-300 hover:bg-bg-dark hover:text-bg-primary"
      >
        {t.cortex.hero.ctaSecondary}
      </a>
    </div>
  </ParticleHero>

  <!-- Core Features Section -->
  <section class="py-24 md:py-32">
    <div class="max-w-[1200px] mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-text-primary">
        {t.cortex.features.headline}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
        {t.cortex.features.items.map((feature) => (
          <GlowCard>
            <h3 class="text-lg font-semibold text-text-primary mb-3">{feature.title}</h3>
            <p class="text-text-secondary text-sm">{feature.description}</p>
          </GlowCard>
        ))}
      </div>
    </div>
  </section>

  <!-- Code Example Section -->
  <section id="code-example" class="py-24 bg-bg-surface/30">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-text-primary mb-12">
        {t.cortex.codeExample.headline}
      </h2>
      <CodeBlock code={t.cortex.codeExample.code} title="cortex-agent.ts" />
    </div>
  </section>

  <!-- Architecture Diagram Section -->
  <section class="py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <ImagePlaceholder
        alt="Cortex 3-layer architecture diagram: Application Layer (agents, tools, prompts), Orchestration Layer (runtime, delegation, cost tracking), Provider Layer (Claude, GPT, Gemini)"
        aspectRatio="16/9"
      />
    </div>
  </section>

  <!-- Use Cases Section -->
  <section class="py-24 md:py-32">
    <div class="max-w-[1200px] mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-text-primary mb-12">
        {t.cortex.useCases.headline}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {t.cortex.useCases.items.map((useCase) => (
          <GlowCard>
            <h3 class="text-xl font-semibold text-text-primary mb-3">{useCase.title}</h3>
            <p class="text-text-secondary">{useCase.description}</p>
          </GlowCard>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    headline={t.home.cta.headline}
    description={t.home.cta.description}
    buttonText={t.home.cta.button}
    buttonHref={getLocalizedPath(lang, '/contact')}
    note={t.home.cta.note}
  />
</BaseLayout>
